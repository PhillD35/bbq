<%= form_for [@event, subscription] do |form| %>
    <%= render partial: 'partials/form_errors', locals: {model: subscription} %>

    <% unless user_signed_in? %>
        <div class="form-group">
          <%= form.label :user_name %>
          <%= form.text_field :user_name, class: 'form-control' %>
        </div>

        <div class="form-group">
          <%= form.label :user_email %>
          <%= form.text_field :user_email, class: 'form-control' %>
        </div>
    <% end %>

    <div class="actions">
      <%= form.submit t('buttons.subscribe'), class: 'btn btn-primary' %>
    </div>
<% end %>
