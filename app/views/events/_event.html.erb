<div class="col-sm-6 col-md-4">

  <div class="thumbnail">

    <%= content_tag 'div', '',
                     class: 'event-background',
                     style: "background-image: url(#{event_thumb(event)})"
    %>

    <div class="thumbnail-inner event-info-inner">
      <div class="caption">
        <div class="event-description">
          <h3><%= link_to event.title, event_path(event) %></h3>

          <h4><%= l event.datetime, format: :short %></h4>

          <div class="buffer-both"><%= link_to shrink_address(event.address), "https://yandex.ru/maps/?text=#{event.address}", target: :blank %></div>
        </div>
      </div>
      <div>
        <% event.visitors.each do |user| %>
          <%= image_tag user_avatar_thumb(user), class: 'img-icon', title: user.name %>
        <% end %>
      </div>
    </div>
  </div>
</div>
